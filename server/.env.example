# ================================================================
# 온기(On-gi) Server — Environment Variables
# ================================================================
# Copy this file to .env and fill in your values.
#
# ── Redis ───────────────────────────────────────────────────────
# Hetzner VPS (local Redis via apt/docker):
#   REDIS_URL=redis://localhost:6379
#   REDIS_URL=redis://:YOUR_PASSWORD@127.0.0.1:6379   # if requirepass set
#
# Managed Redis (Upstash, over TLS):
#   REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT:YOUR_PORT
#
# ── CORS ────────────────────────────────────────────────────────
# The origin(s) your Vite client is served from. Comma-separated for
# multiple (e.g. production domain + www):
#   CORS_ORIGIN=https://on-gi.com,https://www.on-gi.com
# ================================================================

PORT=3001
CORS_ORIGIN=http://localhost:5173
REDIS_URL=redis://localhost:6379

# In production behind Nginx/Caddy set NODE_ENV=production for JSON logs
# NODE_ENV=production

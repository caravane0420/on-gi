# ================================================================
# SyncPlay — Vercel 배포용 환경 변수
# 이 파일을 .env.local로 복사한 후 값을 채우세요.
# ================================================================

# ── Upstash Redis (https://console.upstash.com) ──
# 1. 무료 계정 생성 → 새 Redis 데이터베이스 생성
# 2. REST API 섹션에서 URL과 Token 복사
UPSTASH_REDIS_REST_URL=https://YOUR-ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# ── Pusher Channels (https://dashboard.pusher.com) ──
# 1. 무료 계정 생성 → 새 Channels 앱 생성
# 2. App Keys 탭에서 아래 값 복사
# 3. 중요: App Settings → Enable Client Events 체크!
PUSHER_APP_ID=YOUR_APP_ID
PUSHER_SECRET=YOUR_SECRET
NEXT_PUBLIC_PUSHER_KEY=YOUR_KEY
NEXT_PUBLIC_PUSHER_CLUSTER=ap3

# ================================================================
# 온기(On-gi) Client — Vite Environment Variables
# ================================================================
# Copy to `.env` (or `.env.local`). Vite only exposes vars prefixed
# with VITE_ to the browser.
#
# URL of the Socket.io / Fastify server:
#   Local dev:   http://localhost:3001
#   Production:  https://api.on-gi.com   (your Hetzner domain)
# ================================================================

VITE_SOCKET_URL=http://localhost:3001
